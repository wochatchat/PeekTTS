<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PeekTTS 语音助手"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="无唤醒词 · 全离线 · 后台保活"
            android:textSize="13sp"
            android:textColor="#888"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <!-- Status -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏸️ 待机"
            android:textSize="20sp"
            android:gravity="center"
            android:padding="16dp"
            android:background="#F0F0F0"
            android:layout_marginBottom="12dp" />

        <!-- Toggle button -->
        <Button
            android:id="@+id/btnToggle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="启动助手"
            android:textSize="18sp"
            android:layout_marginBottom="20dp" />

        <!-- Model section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="模型管理"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvModelStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="模型未下载"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="8dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnDownloadModels"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="下载语音模型 (~350MB)"
            android:layout_marginBottom="20dp" />

        <!-- Settings -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="设置"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TTS 语音音色"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/spinnerTtsVoice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <Switch
            android:id="@+id/switchAutoStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="开机自动启动"
            android:layout_marginBottom="20dp" />

        <!-- Conversation log -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="对话记录"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvConversation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:padding="12dp"
            android:background="#FAFAFA"
            android:minHeight="200dp"
            android:text="对话将显示在这里...\n"
            android:scrollbars="vertical" />

    </LinearLayout>
</ScrollView>
